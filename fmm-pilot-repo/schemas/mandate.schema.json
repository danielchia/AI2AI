{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Investor Mandate Schema",
  "description": "Machine-readable investor mandate definition using Gstack forcing questions",
  "type": "object",
  "required": [
    "investor",
    "mandate_id",
    "version",
    "created_at",
    "process_criteria",
    "legal_criteria",
    "compliance_criteria"
  ],
  "properties": {
    "investor": {
      "type": "string",
      "description": "Name of the investor entity",
      "example": "Example PE Fund IV"
    },
    "mandate_id": {
      "type": "string",
      "description": "Unique identifier for this mandate",
      "example": "pef4-2024"
    },
    "version": {
      "type": "string",
      "description": "Mandate version (for tracking updates)",
      "example": "1.0"
    },
    "created_at": {
      "type": "string",
      "format": "date",
      "description": "Date mandate was created",
      "example": "2026-04-30"
    },
    "updated_at": {
      "type": "string",
      "format": "date",
      "description": "Date mandate was last updated"
    },
    "description": {
      "type": "string",
      "description": "Plain-English summary of mandate focus"
    },
    "process_criteria": {
      "type": "object",
      "description": "Investment thesis and operational criteria",
      "required": [
        "primary_use_of_capital",
        "hold_period_years",
        "check_size_usd_millions",
        "target_irr_percent",
        "geography",
        "sectors"
      ],
      "properties": {
        "primary_use_of_capital": {
          "type": "array",
          "description": "Acceptable uses for investor capital",
          "items": {
            "type": "string",
            "enum": [
              "acquisition",
              "growth",
              "debt_paydown",
              "dividend",
              "infrastructure",
              "working_capital"
            ]
          },
          "minItems": 1,
          "example": ["acquisition", "growth"]
        },
        "hold_period_years": {
          "type": "array",
          "description": "Min and max years to exit (IPO, secondary, strategic)",
          "items": {
            "type": "integer",
            "minimum": 1,
            "maximum": 30
          },
          "minItems": 2,
          "maxItems": 2,
          "example": [3, 7]
        },
        "check_size_usd_millions": {
          "type": "array",
          "description": "Min and max capital deployment per deal",
          "items": {
            "type": "number",
            "minimum": 0.1,
            "maximum": 500
          },
          "minItems": 2,
          "maxItems": 2,
          "example": [5, 50]
        },
        "target_irr_percent": {
          "type": "number",
          "description": "Minimum IRR target",
          "minimum": 0,
          "maximum": 100,
          "example": 25
        },
        "geography": {
          "type": "array",
          "description": "Allowed geographies (countries or regions)",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "example": ["US", "CA", "GB", "DE", "SG", "AU"]
        },
        "sectors": {
          "type": "array",
          "description": "Approved industry sectors",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "example": ["software", "fintech", "saas", "healthcare"]
        },
        "exclude_sectors": {
          "type": "array",
          "description": "Explicitly blocked sectors",
          "items": {
            "type": "string"
          },
          "example": ["defense", "fossil_fuels", "weapons"]
        },
        "max_decision_days": {
          "type": "integer",
          "description": "Maximum days allowed for investment decision",
          "minimum": 10,
          "maximum": 365,
          "example": 60
        }
      }
    },
    "legal_criteria": {
      "type": "object",
      "description": "Contractual and legal requirements",
      "required": [
        "required_governance",
        "liquidation_preference"
      ],
      "properties": {
        "required_governance": {
          "type": "array",
          "description": "Required governance rights",
          "items": {
            "type": "string",
            "enum": [
              "observer",
              "board_seat",
              "board_majority",
              "veto_rights",
              "information_rights"
            ]
          },
          "example": ["board_seat", "information_rights"]
        },
        "liquidation_preference": {
          "type": "string",
          "description": "Acceptable liquidation preference structure",
          "enum": [
            "non_participating",
            "participating",
            "capped_participating_2x",
            "capped_participating_3x",
            "multiple_1x",
            "multiple_2x"
          ],
          "example": "non_participating"
        },
        "allowed_anti_dilution_types": {
          "type": "array",
          "description": "Acceptable anti-dilution mechanisms",
          "items": {
            "type": "string",
            "enum": [
              "none",
              "full_ratchet",
              "broad_based_weighted_average",
              "narrow_based_weighted_average"
            ]
          },
          "example": ["broad_based_weighted_average"]
        },
        "max_non_compete_years": {
          "type": "integer",
          "description": "Maximum acceptable non-compete period",
          "minimum": 0,
          "maximum": 10,
          "example": 2
        },
        "requires_drag_along": {
          "type": "boolean",
          "description": "Must have ability to force sale (drag-along)",
          "example": true
        },
        "requires_tag_along": {
          "type": "boolean",
          "description": "Must have ability to follow sale (tag-along)",
          "example": true
        },
        "min_founder_vest_years": {
          "type": "integer",
          "description": "Minimum founder vesting period required",
          "minimum": 0,
          "maximum": 10,
          "example": 4
        },
        "required_carveouts": {
          "type": "array",
          "description": "Required exceptions to standard terms",
          "items": {
            "type": "string",
            "enum": [
              "founder_friendly",
              "equity_pool",
              "charitable_exceptions",
              "family_management"
            ]
          },
          "example": ["founder_friendly"]
        },
        "acceptable_mac_scope": {
          "type": "string",
          "description": "Scope of Material Adverse Change clause",
          "enum": ["narrow", "standard", "broad"],
          "example": "standard"
        }
      }
    },
    "compliance_criteria": {
      "type": "object",
      "description": "Regulatory and reputational risk requirements",
      "required": [
        "allowed_jurisdictions",
        "aml_kyc_required"
      ],
      "properties": {
        "allowed_jurisdictions": {
          "type": "array",
          "description": "Countries/regions where investment is allowed",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "example": ["US", "CA", "GB", "DE", "SG", "AU"]
        },
        "aml_kyc_required": {
          "type": "boolean",
          "description": "Require full AML/KYC verification",
          "example": true
        },
        "blocked_sectors": {
          "type": "array",
          "description": "Sectors that are completely off-limits",
          "items": {
            "type": "string"
          },
          "example": ["gambling", "weapons", "tobacco"]
        },
        "sanctions_check_required": {
          "type": "boolean",
          "description": "Must clear OFAC and other sanctions lists",
          "example": true
        },
        "pep_screening_required": {
          "type": "boolean",
          "description": "Must screen for Politically Exposed Persons",
          "example": true
        },
        "min_esg_rating": {
          "type": "string",
          "description": "Minimum ESG compliance rating acceptable",
          "enum": ["green", "yellow", "red"],
          "example": "yellow"
        },
        "export_control_acceptable": {
          "type": "boolean",
          "description": "Can invest in companies with export controls",
          "example": false
        },
        "requires_privacy_compliance": {
          "type": "boolean",
          "description": "Must be GDPR/privacy compliant",
          "example": true
        },
        "max_reputational_risk": {
          "type": "string",
          "description": "Maximum reputational risk tolerance",
          "enum": ["clear", "minor", "elevated"],
          "example": "minor"
        },
        "reputational_review_required": {
          "type": "boolean",
          "description": "Do media/controversy checks on founders and companies",
          "example": true
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Additional context about this mandate",
      "properties": {
        "fund_size_usd_millions": {
          "type": "number",
          "description": "Total fund size (for context)",
          "example": 150
        },
        "target_portfolio_size": {
          "type": "integer",
          "description": "Expected number of investments",
          "example": 8
        },
        "key_contact": {
          "type": "string",
          "description": "Name/email of mandate owner",
          "example": "investor@example.com"
        },
        "approval_required_from": {
          "type": "array",
          "description": "Who must approve investments matching this mandate",
          "items": {
            "type": "string"
          },
          "example": ["investment_committee", "managing_partner"]
        }
      }
    }
  }
}
