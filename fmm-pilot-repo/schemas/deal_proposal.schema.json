{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Deal Proposal Schema",
  "description": "Standardized deal submission for evaluation against investor mandate",
  "type": "object",
  "required": [
    "deal_id",
    "company_name",
    "submission_date",
    "dealmaker",
    "process_section",
    "legal_section",
    "compliance_section"
  ],
  "properties": {
    "deal_id": {
      "type": "string",
      "description": "Unique identifier for this deal",
      "example": "DEAL-2026-0001"
    },
    "company_name": {
      "type": "string",
      "description": "Legal name of company being invested in",
      "example": "LinkLogis Pte Ltd"
    },
    "submission_date": {
      "type": "string",
      "format": "date",
      "description": "Date proposal was submitted",
      "example": "2026-04-30"
    },
    "dealmaker": {
      "type": "object",
      "description": "Information about the dealmaker/broker submitting",
      "properties": {
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "organization": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        }
      }
    },
    "mandate_ids": {
      "type": "array",
      "description": "Which investor mandates is this being evaluated against",
      "items": {
        "type": "string"
      },
      "example": ["pef4-2024", "pef4-2024-alt"]
    },
    "process_section": {
      "type": "object",
      "description": "Answers to Process Agent forcing questions",
      "required": [
        "use_of_capital",
        "hold_period_years",
        "check_size_usd_millions",
        "projected_irr",
        "geographies",
        "primary_sector"
      ],
      "properties": {
        "use_of_capital": {
          "type": "string",
          "description": "What will capital be used for",
          "enum": [
            "acquisition",
            "growth",
            "debt_paydown",
            "dividend",
            "infrastructure",
            "working_capital"
          ],
          "example": "acquisition"
        },
        "capital_use_details": {
          "type": "string",
          "description": "Detailed explanation of capital use",
          "example": "Acquiring competing trade receivables platform to expand regional coverage"
        },
        "hold_period_years": {
          "type": "integer",
          "description": "Expected years to exit",
          "minimum": 1,
          "maximum": 30,
          "example": 4
        },
        "exit_strategy": {
          "type": "string",
          "description": "Expected exit mechanism",
          "enum": ["ipo", "strategic_acquisition", "secondary_sale", "dividend_recapitalization"],
          "example": "strategic_acquisition"
        },
        "check_size_usd_millions": {
          "type": "number",
          "description": "Capital requested from this investor",
          "minimum": 0.1,
          "maximum": 500,
          "example": 20
        },
        "total_raise_usd_millions": {
          "type": "number",
          "description": "Total capital raise (for context)",
          "example": 50
        },
        "projected_irr": {
          "type": "number",
          "description": "Projected Internal Rate of Return",
          "minimum": 0,
          "maximum": 100,
          "example": 28
        },
        "irr_assumptions": {
          "type": "string",
          "description": "How IRR was calculated",
          "example": "Based on 4-year hold, 3x revenue exit multiple, 40% annual growth"
        },
        "geographies": {
          "type": "array",
          "description": "Countries where company operates",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "example": ["SG", "MY", "TH", "VN"]
        },
        "primary_sector": {
          "type": "string",
          "description": "Main industry classification",
          "example": "fintech"
        },
        "subsectors": {
          "type": "array",
          "description": "More specific sectors",
          "items": {
            "type": "string"
          },
          "example": ["trade_finance", "supply_chain"]
        },
        "value_drivers": {
          "type": "array",
          "description": "How value will be created (2-3 primary drivers)",
          "items": {
            "type": "string",
            "enum": [
              "organic_growth",
              "multiple_expansion",
              "bolt_on_acquisition",
              "operational_improvement",
              "market_consolidation"
            ]
          },
          "example": ["bolt_on_acquisition", "organic_growth"]
        },
        "value_driver_details": {
          "type": "string",
          "description": "Detailed plan for value creation",
          "example": "We will acquire 2-3 competitors in APAC to consolidate market, integrate tech stack, and cross-sell to expanded customer base"
        },
        "decision_deadline": {
          "type": "string",
          "format": "date",
          "description": "When does investor need to decide",
          "example": "2026-06-15"
        }
      }
    },
    "legal_section": {
      "type": "object",
      "description": "Answers to Legal Agent forcing questions",
      "required": [
        "governance_rights",
        "liquidation_preference"
      ],
      "properties": {
        "governance_rights": {
          "type": "array",
          "description": "What control/influence investor will have",
          "items": {
            "type": "string",
            "enum": [
              "observer",
              "board_seat",
              "board_majority",
              "veto_rights",
              "information_rights"
            ]
          },
          "example": ["board_seat", "information_rights", "veto_rights"]
        },
        "governance_details": {
          "type": "string",
          "description": "Details of governance structure",
          "example": "One board seat, monthly financial reports, veto rights on hiring/spending >$1M"
        },
        "liquidation_preference": {
          "type": "string",
          "description": "Liquidation preference structure",
          "enum": [
            "non_participating",
            "participating",
            "capped_participating_2x",
            "capped_participating_3x",
            "multiple_1x",
            "multiple_2x"
          ],
          "example": "participating"
        },
        "anti_dilution": {
          "type": "string",
          "description": "Anti-dilution protection",
          "enum": [
            "none",
            "full_ratchet",
            "broad_based_weighted_average",
            "narrow_based_weighted_average"
          ],
          "example": "broad_based_weighted_average"
        },
        "non_compete_years": {
          "type": "integer",
          "description": "Non-compete period for founders/employees",
          "minimum": 0,
          "maximum": 10,
          "example": 2
        },
        "has_drag_along": {
          "type": "boolean",
          "description": "Investor can force sale (drag-along rights)",
          "example": true
        },
        "has_tag_along": {
          "type": "boolean",
          "description": "Investor can follow sale (tag-along rights)",
          "example": true
        },
        "founder_vest_schedule": {
          "type": "object",
          "description": "Founder equity vesting terms",
          "properties": {
            "years": {
              "type": "integer",
              "example": 4
            },
            "cliff_years": {
              "type": "number",
              "example": 1
            }
          }
        },
        "mac_clause_scope": {
          "type": "string",
          "description": "Material Adverse Change clause scope",
          "enum": ["narrow", "standard", "broad"],
          "example": "standard"
        },
        "carveouts": {
          "type": "array",
          "description": "Exception clauses built in",
          "items": {
            "type": "string"
          },
          "example": ["founder_friendly", "equity_pool"]
        },
        "documents_attached": {
          "type": "array",
          "description": "Legal documents submitted",
          "items": {
            "type": "string"
          },
          "example": ["term_sheet.pdf", "cap_table.xlsx", "articles_of_incorporation.pdf"]
        }
      }
    },
    "compliance_section": {
      "type": "object",
      "description": "Answers to Compliance Agent forcing questions",
      "required": [
        "jurisdictions",
        "aml_kyc_status",
        "sanctions_screening_result"
      ],
      "properties": {
        "jurisdictions": {
          "type": "array",
          "description": "Countries where company operates/is registered",
          "items": {
            "type": "object",
            "properties": {
              "country": {
                "type": "string"
              },
              "operations": {
                "type": "string",
                "description": "Type of operations (HQ, R&D, sales, etc)"
              },
              "risk_level": {
                "type": "string",
                "enum": ["low", "medium", "high", "blocked"]
              }
            }
          }
        },
        "aml_kyc_status": {
          "type": "string",
          "description": "Anti-Money Laundering/Know Your Customer status",
          "enum": ["complete", "pending", "failed"],
          "example": "complete"
        },
        "aml_kyc_notes": {
          "type": "string",
          "description": "Details on AML/KYC verification",
          "example": "All beneficial owners verified through third-party KYC provider, completed 2026-04-15"
        },
        "sanctions_screening_result": {
          "type": "string",
          "description": "OFAC/sanctions screening outcome",
          "enum": ["clean", "review", "blocked"],
          "example": "clean"
        },
        "pep_screening_result": {
          "type": "string",
          "description": "Politically Exposed Persons screening",
          "enum": ["clean", "review", "blocked"],
          "example": "clean"
        },
        "primary_sector": {
          "type": "string",
          "description": "Primary business sector for compliance check",
          "example": "fintech"
        },
        "sector_status": {
          "type": "string",
          "description": "Is sector on any restricted list",
          "enum": ["allowed", "monitored", "blocked"],
          "example": "allowed"
        },
        "export_control_status": {
          "type": "string",
          "description": "Does company use/export controlled technology",
          "enum": ["not_applicable", "compliant", "pending", "blocked"],
          "example": "not_applicable"
        },
        "esg_rating": {
          "type": "string",
          "description": "Environmental/Social/Governance compliance rating",
          "enum": ["green", "yellow", "red"],
          "example": "green"
        },
        "esg_notes": {
          "type": "string",
          "description": "Details on ESG status",
          "example": "SOC 2 Type II certified, no labor violations, diverse leadership team"
        },
        "data_privacy_status": {
          "type": "string",
          "description": "GDPR/privacy compliance",
          "enum": ["not_applicable", "compliant", "in_progress", "at_risk"],
          "example": "compliant"
        },
        "reputational_risk_level": {
          "type": "string",
          "description": "Public controversy or legal risk",
          "enum": ["clear", "minor", "elevated", "blocked"],
          "example": "clear"
        },
        "reputational_notes": {
          "type": "string",
          "description": "Details on any reputational issues",
          "example": "No major controversies; one labor lawsuit settled 2025"
        },
        "benefical_ownership": {
          "type": "array",
          "description": "List of beneficial owners (for compliance tracking)",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "nationality": {
                "type": "string"
              },
              "ownership_percent": {
                "type": "number"
              },
              "pep_status": {
                "type": "string"
              },
              "sanctions_status": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "financial_highlights": {
      "type": "object",
      "description": "Key financial metrics for quick reference",
      "properties": {
        "current_year_revenue_usd_millions": {
          "type": "number"
        },
        "annual_growth_rate_percent": {
          "type": "number"
        },
        "profitability_status": {
          "type": "string",
          "enum": ["profitable", "breakeven", "pre_revenue", "cash_burn"]
        },
        "runway_months": {
          "type": "integer",
          "description": "Months of cash remaining"
        },
        "current_valuation_usd_millions": {
          "type": "number"
        },
        "post_investment_valuation_usd_millions": {
          "type": "number"
        }
      }
    },
    "team": {
      "type": "object",
      "description": "Leadership team summary",
      "properties": {
        "ceo": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "background": {
              "type": "string"
            }
          }
        },
        "key_executives": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "role": {
                "type": "string"
              },
              "background": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "attachments": {
      "type": "array",
      "description": "Supporting documents",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string",
      "description": "Any additional context for evaluators"
    }
  }
}
